<section class="page-header">
  <div>
    <p class="eyebrow">Caixa</p>
    <h1><%= title %></h1>
  </div>
</section>

<form class="filter-bar" method="get" action="/cash-summary">
  <label>
    Início
    <input type="date" name="start_date" value="<%= filters.start_date || '' %>" />
  </label>
  <label>
    Fim
    <input type="date" name="end_date" value="<%= filters.end_date || '' %>" />
  </label>
  <button class="button secondary" type="submit">Filtrar</button>
  <a class="button ghost" href="/cash-summary">Limpar</a>
</form>

<%
  const cashDenominations = [50, 20, 10, 5, 2, 1, 0.5, 0.2, 0.1, 0.05, 0.02, 0.01];
  const registeredCashTotal = Number(cashClosing && cashClosing.registeredCashTotal ? cashClosing.registeredCashTotal : 0);
  const cashClosingKey = [
    'cash-closing',
    filters.start_date || 'all',
    filters.end_date || filters.start_date || 'all'
  ].join(':');
%>

<section
  class="panel cash-closing-panel"
  data-cash-closing
  data-cash-registered-total="<%= registeredCashTotal %>"
  data-cash-closing-key="<%= cashClosingKey %>"
  data-locale="<%= locale %>"
>
  <div class="panel-header">
    <h2>Fecho de caixa</h2>
    <button class="button ghost" type="button" data-cash-closing-clear>Limpar contagem</button>
  </div>

  <div class="cash-closing-layout">
    <div class="cash-closing-inputs">
      <label>
        Fundo de maneio na abertura
        <input type="text" inputmode="decimal" placeholder="0,00 €" data-cash-opening />
      </label>
      <label>
        Dinheiro contado no fim
        <input type="text" inputmode="decimal" placeholder="0,00 €" data-cash-counted />
      </label>
    </div>

    <div class="cash-breakdown">
      <div class="cash-breakdown-header">
        <strong>Notas e moedas</strong>
        <span data-cash-denomination-total><%= money(0) %></span>
      </div>
      <div class="cash-denomination-grid">
        <% cashDenominations.forEach((value) => { %>
          <label class="cash-denomination">
            <span><%= money(value) %></span>
            <input type="number" min="0" step="1" inputmode="numeric" data-cash-denomination="<%= value %>" />
          </label>
        <% }) %>
      </div>
    </div>

    <div class="cash-closing-summary">
      <div>
        <span>Dinheiro registado</span>
        <strong data-cash-registered><%= money(registeredCashTotal) %></strong>
      </div>
      <div>
        <span>Esperado em caixa</span>
        <strong data-cash-expected><%= money(registeredCashTotal) %></strong>
      </div>
      <div>
        <span>A retirar</span>
        <strong data-cash-withdraw><%= money(0) %></strong>
      </div>
      <div class="cash-difference-card" data-cash-difference-card>
        <span>Diferença</span>
        <strong data-cash-difference><%= money(0) %></strong>
      </div>
    </div>
  </div>

  <div class="cash-source-list">
    <span>Bar: <strong><%= money(cashClosing.barTotal || 0) %></strong></span>
    <span>Merchandising: <strong><%= money(cashClosing.merchTotal || 0) %></strong></span>
    <span>Quotas: <strong><%= money(cashClosing.duesTotal || 0) %></strong></span>
  </div>
</section>

<section class="report-grid">
  <article class="panel">
    <div class="panel-header"><h2>Bar (Dinheiro)</h2></div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Vendas</th><th>Total</th></tr></thead>
        <tbody>
          <tr>
            <td><%= barCash.sales_count || 0 %></td>
            <td><%= money(barCash.total || 0) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel">
    <div class="panel-header"><h2>Bar (Outros pagamentos)</h2></div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Método</th><th>Vendas</th><th>Total</th></tr></thead>
        <tbody>
          <% barOtherPayments.forEach((row) => { %>
            <tr>
              <td><%= row.name %></td>
              <td><%= row.sales_count %></td>
              <td><%= money(row.total) %></td>
            </tr>
          <% }) %>
          <% if (barOtherPayments.length === 0) { %><tr><td colspan="3">Sem dados.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel">
    <div class="panel-header"><h2>Merchandising (Dinheiro)</h2></div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Vendas</th><th>Total</th></tr></thead>
        <tbody>
          <tr>
            <td><%= merchCash.sales_count || 0 %></td>
            <td><%= money(merchCash.total || 0) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel">
    <div class="panel-header"><h2>Merchandising (Outros pagamentos)</h2></div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Método</th><th>Vendas</th><th>Total</th></tr></thead>
        <tbody>
          <% merchOtherPayments.forEach((row) => { %>
            <tr>
              <td><%= row.name %></td>
              <td><%= row.sales_count %></td>
              <td><%= money(row.total) %></td>
            </tr>
          <% }) %>
          <% if (merchOtherPayments.length === 0) { %><tr><td colspan="3">Sem dados.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel">
    <div class="panel-header"><h2>Quotas (Dinheiro)</h2></div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Pagamentos</th><th>Total</th></tr></thead>
        <tbody>
          <tr>
            <td><%= duesCash.payments_count || 0 %></td>
            <td><%= money(duesCash.total || 0) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </article>
</section>
