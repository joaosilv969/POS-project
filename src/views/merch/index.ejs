<section class="pos-header">
  <div>
    <p class="eyebrow">Merchandising</p>
    <h1>Venda de merchandising</h1>
    <p class="text-muted">Registe vendas de merchandising com número e nome de sócio. Esta vista é totalmente separada do ponto de venda do bar.</p>
  </div>
</section>

<section
  class="pos-layout"
  data-merch
  data-locale="<%= locale %>"
  data-sale-endpoint="/merchandising/sale"
  data-cash-method-id="<%= cashMethodId || '' %>"
  data-empty-cart-message="<%= t('Adicione produtos para iniciar a venda.') %>"
  data-out-of-stock-message="<%= t('Produto sem stock disponível.') %>"
  data-increase-stock-error="<%= t('Não existe stock suficiente para aumentar a quantidade.') %>"
  data-quantity-stock-error="<%= t('Não existe stock suficiente para essa quantidade.') %>"
  data-missing-items-message="<%= t('Adicione produtos antes de finalizar.') %>"
  data-missing-member-message="<%= t('Nº sócio e nome do sócio são obrigatórios para vendas de merchandising.') %>"
  data-cash-total-error="<%= t('Valor recebido insuficiente para o total da venda.') %>"
  data-finish-sale-error="<%= t('Não foi possível finalizar a venda.') %>"
>
  <div class="pos-products">
    <div class="category-tabs" role="tablist" aria-label="Categorias">
      <button class="active" type="button" data-category-filter="all">Todas</button>
      <% categories.forEach((category) => { %>
        <button type="button" data-category-filter="<%= category.id %>"><%= category.name %></button>
      <% }) %>
    </div>

    <div class="product-grid">
      <% products.forEach((product) => { %>
        <button
          class="product-tile"
          type="button"
          data-product-id="<%= product.id %>"
          data-product-name="<%= product.name %>"
          data-product-price="<%= product.price %>"
          data-product-stock="<%= product.stock %>"
          data-product-category="<%= product.category_id %>"
        >
          <span class="tile-image">
            <% if (product.image_file) { %>
              <img src="/uploads/<%= product.image_file %>" alt="<%= product.name %>" />
            <% } else { %>
              <span><%= product.name.slice(0, 1) %></span>
            <% } %>
          </span>
          <span class="tile-name"><%= product.name %></span>
          <% if (product.size) { %>
            <span class="tile-subtitle"><%= product.size %></span>
          <% } %>
          <span class="tile-meta">
            <strong><%= money(product.price) %></strong>
            <small>Stock <%= product.stock %></small>
          </span>
        </button>
      <% }) %>
    </div>
  </div>

  <aside class="cart-panel">
    <div class="panel-header">
      <h2>Venda atual</h2>
      <button class="button ghost" type="button" data-clear-cart>Limpar</button>
    </div>

    <div class="cart-items" data-cart-items>
      <div class="empty-cart">Adicione produtos para iniciar a venda.</div>
    </div>

    <div class="cart-summary">
      <label>
        Pagamento
        <select data-payment-method>
          <% paymentMethods.forEach((method) => { %>
            <option value="<%= method.id %>"><%= method.name %></option>
          <% }) %>
        </select>
      </label>

      <label>
        Nº Sócio
        <input type="text" name="member_number" data-member-number placeholder="Obrigatório" required />
      </label>

      <label>
        Nome do sócio
        <input
          type="text"
          name="member_name"
          data-member-name
          data-member-autocomplete
          list="members-datalist"
          placeholder="Escreva e selecione (obrigatório)"
          autocomplete="off"
          required
        />
        <datalist id="members-datalist" data-members-datalist></datalist>
      </label>

      <div class="cash-payment-section" data-cash-payment>
        <label>
          Valor recebido
          <input type="text" data-cash-received data-virtual-keyboard="off" placeholder="0,00 €" inputmode="decimal" />
        </label>

        <div class="cash-keypad">
          <button type="button" data-key="1">1</button>
          <button type="button" data-key="2">2</button>
          <button type="button" data-key="3">3</button>
          <button type="button" data-key="4">4</button>
          <button type="button" data-key="5">5</button>
          <button type="button" data-key="6">6</button>
          <button type="button" data-key="7">7</button>
          <button type="button" data-key="8">8</button>
          <button type="button" data-key="9">9</button>
          <button type="button" data-key="0">0</button>
          <button type="button" data-key=",">,</button>
          <button type="button" data-key="clear">⌫</button>
        </div>

        <div class="cash-change">
          <span>Troco</span>
          <strong data-cash-change>0,00 €</strong>
        </div>
      </div>

      <div class="cart-total">
        <span>Total</span>
        <strong data-cart-total>0,00 €</strong>
      </div>
      <p class="form-error" data-pos-error hidden></p>
      <button class="button primary full large" type="button" data-finish-sale>Finalizar venda</button>
    </div>
  </aside>
</section>

<script src="/assets/js/merch.js?v=<%= assetVersion %>"></script>
