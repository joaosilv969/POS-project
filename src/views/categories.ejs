<section class="page-header">
  <div>
    <p class="eyebrow">Catálogo</p>
    <h1>Categorias</h1>
  </div>
  <div class="button-row">
    <a class="button <%= scope === 'bar' ? 'primary' : 'secondary' %>" href="/categories/bar">Bar</a>
    <a class="button <%= scope === 'merchandising' ? 'primary' : 'secondary' %>" href="/categories/merchandising">Merchandising</a>
  </div>
</section>

<section class="two-column align-start">
  <form class="panel form-stack" method="post" action="/categories">
    <div class="panel-header">
      <h2>Nova categoria</h2>
    </div>
    <label>
      Nome
      <input name="name" required />
    </label>
    <label>
      Descricao
      <input name="description" />
    </label>
    <input type="hidden" name="scope" value="<%= scope || 'bar' %>" />
    <button class="button primary" type="submit">Criar categoria</button>
  </form>

  <div class="panel">
    <div class="panel-header">
      <h2>Categorias existentes</h2>
    </div>
    <div class="category-list">
      <% categories.forEach((category) => { %>
        <form class="category-row" method="post" action="/categories/<%= category.id %>">
          <input name="name" required value="<%= category.name %>" />
          <input name="description" value="<%= category.description || '' %>" />
          <input type="hidden" name="scope" value="<%= scope || category.scope || 'bar' %>" />
          <label class="toggle-field compact">
            <input type="checkbox" name="active" <%= category.active ? "checked" : "" %> />
            Ativa
          </label>
          <span class="pill"><%= category.product_count %> produtos</span>
          <button class="button secondary" type="submit">Guardar</button>
        </form>
        <form method="post" action="/categories/<%= category.id %>/delete" data-confirm="Inativar esta categoria?">
          <button class="button ghost full" type="submit">Inativar categoria</button>
        </form>
      <% }) %>
    </div>
  </div>
</section>
