<section class="page-header">
  <div>
    <p class="eyebrow">Análise</p>
    <h1>Analytics</h1>
    <p class="text-muted">Visão geral com filtros, gráficos e tabelas de detalhe.</p>
  </div>
  <div class="button-row">
    <a class="button secondary" href="/reports/merchandising">Merchandising</a>
    <a class="button secondary" href="/reports/dues">Cotas</a>
  </div>
</section>

<nav class="report-tabs" aria-label="Secções de relatórios">
  <a class="active" href="/reports<%= queryString ? `?${queryString}` : '' %>">Overview</a>
  <a href="/sales/bar<%= queryString ? `?${queryString}` : '' %>">Bar</a>
  <a href="/reports/merchandising<%= queryString ? `?${queryString}` : '' %>">Merchandising</a>
  <a href="/reports/dues">Cotas</a>
  <a href="/stock">Stock</a>
</nav>

<form class="panel report-filter-panel" method="get" action="/reports">
  <div class="report-filter-grid">
    <label>
      Início
      <input type="date" name="start_date" value="<%= filters.startDate %>" />
    </label>
    <label>
      Fim
      <input type="date" name="end_date" value="<%= filters.endDate %>" />
    </label>
    <label>
      Área
      <select name="area">
        <option value="all" <%= filters.area === 'all' ? 'selected' : '' %>>Todas</option>
        <option value="bar" <%= filters.area === 'bar' ? 'selected' : '' %>>Bar</option>
        <option value="merchandising" <%= filters.area === 'merchandising' ? 'selected' : '' %>>Merchandising</option>
      </select>
    </label>
    <label>
      Pagamento
      <select name="payment_method_id">
        <option value="">Todos</option>
        <% paymentMethodOptions.forEach((method) => { %>
          <option value="<%= method.id %>" <%= filters.paymentMethodId === method.id ? 'selected' : '' %>><%= method.name %></option>
        <% }) %>
      </select>
    </label>
    <label>
      Funcionário
      <select name="user_id">
        <option value="">Todos</option>
        <% userOptions.forEach((user) => { %>
          <option value="<%= user.id %>" <%= filters.userId === user.id ? 'selected' : '' %>><%= user.name %></option>
        <% }) %>
      </select>
    </label>
    <label>
      Categoria
      <select name="category_id">
        <option value="">Todas</option>
        <% categoryOptions.forEach((category) => { %>
          <option value="<%= category.id %>" <%= filters.categoryId === category.id ? 'selected' : '' %>><%= category.scope === 'merchandising' ? 'Merch - ' : 'Bar - ' %><%= category.name %></option>
        <% }) %>
      </select>
    </label>
  </div>
  <div class="form-actions">
    <button class="button secondary" type="submit">Filtrar</button>
    <a class="button ghost" href="/reports">Limpar</a>
  </div>
</form>

<section class="analytics-kpis">
  <article class="stat-card">
    <span>Faturação</span>
    <strong><%= money(summary.total || 0) %></strong>
  </article>
  <article class="stat-card">
    <span>Vendas</span>
    <strong><%= summary.sales_count || 0 %></strong>
  </article>
  <article class="stat-card">
    <span>Artigos</span>
    <strong><%= summary.items_sold || 0 %></strong>
  </article>
  <article class="stat-card">
    <span>Venda média</span>
    <strong><%= money(summary.average_sale || 0) %></strong>
  </article>
  <article class="stat-card">
    <span>Dinheiro</span>
    <strong><%= money(summary.cash_total || 0) %></strong>
  </article>
  <article class="stat-card">
    <span>Outros pagamentos</span>
    <strong><%= money(summary.non_cash_total || 0) %></strong>
  </article>
</section>

<section class="analytics-grid">
  <article class="panel analytics-wide">
    <div class="panel-header">
      <h2>Tendência por dia</h2>
      <a class="button ghost" href="<%= exportLink('daily') %>">CSV</a>
    </div>
    <div class="trend-chart">
      <% salesByDay.forEach((row) => { %>
        <div class="trend-bar" title="<%= row.day %>: <%= money(row.total) %>">
          <span style="height:<%= Math.max(8, row.percent) %>%"></span>
          <small><%= row.day.slice(5) %></small>
        </div>
      <% }) %>
      <% if (salesByDay.length === 0) { %><div class="empty-state">Sem dados.</div><% } %>
    </div>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h2>Pagamentos</h2>
      <a class="button ghost" href="<%= exportLink('payments') %>">CSV</a>
    </div>
    <div class="bar-list">
      <% paymentTotals.forEach((row) => { %>
        <div class="bar-row">
          <div><strong><%= row.name %></strong><span><%= row.sales_count %> vendas</span></div>
          <div class="bar-track"><span style="width:<%= row.percent %>%"></span></div>
          <b><%= money(row.total) %></b>
        </div>
      <% }) %>
      <% if (paymentTotals.length === 0) { %><div class="empty-state">Sem dados.</div><% } %>
    </div>
  </article>
</section>

<section class="analytics-grid">
  <article class="panel">
    <div class="panel-header">
      <h2>Produtos</h2>
      <a class="button ghost" href="<%= exportLink('products') %>">CSV</a>
    </div>
    <div class="bar-list">
      <% salesByProduct.slice(0, 10).forEach((row) => { %>
        <div class="bar-row">
          <div><strong><%= row.product_name %></strong><span><%= row.quantity %> un. · <%= row.category_name %></span></div>
          <div class="bar-track"><span style="width:<%= row.percent %>%"></span></div>
          <b><%= money(row.total) %></b>
        </div>
      <% }) %>
      <% if (salesByProduct.length === 0) { %><div class="empty-state">Sem dados.</div><% } %>
    </div>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h2>Funcionários</h2>
      <a class="button ghost" href="<%= exportLink('employees') %>">CSV</a>
    </div>
    <div class="bar-list">
      <% salesByEmployee.forEach((row) => { %>
        <div class="bar-row">
          <div><strong><%= row.name %></strong><span><%= row.sales_count %> vendas</span></div>
          <div class="bar-track"><span style="width:<%= row.percent %>%"></span></div>
          <b><%= money(row.total) %></b>
        </div>
      <% }) %>
      <% if (salesByEmployee.length === 0) { %><div class="empty-state">Sem dados.</div><% } %>
    </div>
  </article>

  <article class="panel">
    <div class="panel-header">
      <h2>Categorias</h2>
      <a class="button ghost" href="<%= exportLink('categories') %>">CSV</a>
    </div>
    <div class="bar-list">
      <% salesByCategory.forEach((row) => { %>
        <div class="bar-row">
          <div><strong><%= row.name %></strong><span><%= row.scope === 'bar' ? 'Bar' : 'Merchandising' %> · <%= row.quantity %> un.</span></div>
          <div class="bar-track"><span style="width:<%= row.percent %>%"></span></div>
          <b><%= money(row.total) %></b>
        </div>
      <% }) %>
      <% if (salesByCategory.length === 0) { %><div class="empty-state">Sem dados.</div><% } %>
    </div>
  </article>

  <article class="panel">
    <div class="panel-header"><h2>Stock baixo</h2></div>
    <div class="bar-list stock-bars">
      <% lowStock.slice(0, 10).forEach((product) => { %>
        <% const stockPercent = Math.min(100, Math.round((Number(product.stock || 0) / Math.max(1, Number(product.low_stock_threshold || 1))) * 100)); %>
        <div class="bar-row">
          <div><strong><%= product.name %></strong><span><%= product.category_name %></span></div>
          <div class="bar-track danger"><span style="width:<%= stockPercent %>%"></span></div>
          <b><%= product.stock %>/<%= product.low_stock_threshold %></b>
        </div>
      <% }) %>
      <% if (lowStock.length === 0) { %><div class="empty-state">Sem produtos com stock baixo.</div><% } %>
    </div>
  </article>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Detalhe por dia</h2>
    <a class="button ghost" href="<%= exportLink('daily') %>">Exportar CSV</a>
  </div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Dia</th><th>Vendas</th><th>Artigos</th><th>Total</th></tr></thead>
      <tbody>
        <% salesByDay.slice().reverse().forEach((row) => { %>
          <tr><td><%= row.day %></td><td><%= row.sales_count %></td><td><%= row.quantity %></td><td><%= money(row.total) %></td></tr>
        <% }) %>
        <% if (salesByDay.length === 0) { %><tr><td colspan="4">Sem dados.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Detalhe por produto</h2>
    <a class="button ghost" href="<%= exportLink('products') %>">Exportar CSV</a>
  </div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Produto</th><th>Categoria</th><th>Área</th><th>Vendas</th><th>Qtd.</th><th>Total</th></tr></thead>
      <tbody>
        <% salesByProduct.forEach((row) => { %>
          <tr>
            <td><%= row.product_name %></td>
            <td><%= row.category_name %></td>
            <td><%= row.product_type === 'bar' ? 'Bar' : 'Merchandising' %></td>
            <td><%= row.sales_count %></td>
            <td><%= row.quantity %></td>
            <td><%= money(row.total) %></td>
          </tr>
        <% }) %>
        <% if (salesByProduct.length === 0) { %><tr><td colspan="6">Sem dados.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</section>
