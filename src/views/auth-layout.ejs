<!doctype html>
<html lang="<%= locale %>" data-theme="<%= theme %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="<%= theme === 'dark' ? 'dark' : 'light' %>" />
    <title><%= title %> | <%= appName %></title>
    <link rel="stylesheet" href="/assets/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body
    class="auth-page"
    bgcolor="<%= theme === 'dark' ? '#0b0b0d' : '#f3f3f4' %>"
    data-theme="<%= theme %>"
    data-locale="<%= locale %>"
    data-vk-aria-label="<%= t('Teclado no ecrã') %>"
    data-vk-title="<%= t('Teclado') %>"
    data-vk-close-label="<%= t('Fechar') %>"
    data-vk-space-label="<%= t('Espaço') %>"
    data-vk-render-error="<%= t('Erro ao carregar teclado.') %>"
  >
    <button
      class="theme-icon-button auth-theme-toggle"
      type="button"
      data-dark-mode-toggle
      data-icon-only
      data-light-mode-label="<%= t('Mudar para modo claro') %>"
      data-dark-mode-label="<%= t('Mudar para modo escuro') %>"
      aria-label="<%= theme === 'dark' ? t('Mudar para modo claro') : t('Mudar para modo escuro') %>"
      aria-pressed="<%= theme === 'dark' ? 'true' : 'false' %>"
      title="<%= theme === 'dark' ? t('Mudar para modo claro') : t('Mudar para modo escuro') %>"
    >
      <span class="theme-icon" aria-hidden="true"></span>
    </button>

    <main class="auth-card">
      <%- include("partials/flash") %>
      <%- body %>
    </main>

    <script src="/assets/js/app.js?v=<%= assetVersion %>"></script>
    <script src="/assets/js/virtual-keyboard.js?v=<%= assetVersion %>"></script>
  </body>
</html>
