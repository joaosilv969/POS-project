<section class="page-header">
  <div>
    <p class="eyebrow">Clube</p>
    <h1>Sócios</h1>
  </div>
  <div class="button-row">
    <% if (currentUser && currentUser.role === 'admin') { %>
      <a class="button ghost" href="/members/import/example.csv">Download exemplo CSV</a>
    <% } %>
    <a class="button primary" href="/members/new">Novo sócio</a>
  </div>
</section>

<% if (currentUser && currentUser.role === 'admin') { %>
  <form class="panel form-stack" method="post" action="/members/import" enctype="multipart/form-data">
    <div class="panel-header">
      <h2>Importar sócios por CSV</h2>
      <a class="button ghost" href="/members/import/example.csv">Exemplo</a>
    </div>
    <p class="text-muted">Aceita ficheiros CSV com cabeçalho como <strong>member_number,name,active</strong> ou sem cabeçalho. Se o nº de sócio já existir, o registo é atualizado.</p>
    <label>
      Ficheiro CSV
      <input type="file" name="csv_file" accept=".csv,text/csv,.txt" required />
    </label>
    <div class="form-actions">
      <button class="button primary" type="submit">Importar CSV</button>
    </div>
  </form>
<% } %>

<section class="panel">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Nº Sócio</th>
          <th>Nome</th>
          <th>Estado</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% members.forEach((member) => { %>
          <tr>
            <td><%= member.member_number %></td>
            <td><%= member.name %></td>
            <td><span class="<%= member.active ? 'pill success' : 'pill muted' %>"><%= member.active ? "Ativo" : "Inativo" %></span></td>
            <td class="actions-cell">
              <% if (currentUser && currentUser.role === 'admin') { %>
                <a class="button secondary" href="/members/<%= member.id %>/edit">Editar</a>
                <% if (member.active) { %>
                  <form method="post" action="/members/<%= member.id %>/delete" data-confirm="Inativar este sócio?">
                    <button class="button danger" type="submit">Inativar</button>
                  </form>
                <% } %>
              <% } %>
            </td>
          </tr>
        <% }) %>
        <% if (members.length === 0) { %>
          <tr><td colspan="4">Sem sócios registados.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
