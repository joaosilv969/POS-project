<section class="page-header">
  <div>
    <p class="eyebrow">Configuração</p>
    <h1>Marca</h1>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Aplicação</h2>
  </div>

  <form class="form-stack" method="post" action="/settings/app">
    <label>
      Nome da aplicação
      <input name="app_name" maxlength="40" placeholder="Ex.: Motoclube" value="<%= appName || '' %>" />
    </label>

    <label>
      Subtítulo
      <input name="app_subtitle" maxlength="60" placeholder="Ex.: Gestão de vendas" value="<%= appSubtitle || '' %>" />
    </label>

    <div class="form-grid">
      <label>
        Prefixo recibo (Bar)
        <input name="receipt_prefix_bar" maxlength="3" placeholder="Ex.: V" value="<%= receiptPrefixBar || 'V' %>" />
      </label>
      <label>
        Prefixo recibo (Merchandising)
        <input name="receipt_prefix_merchandising" maxlength="3" placeholder="Ex.: M" value="<%= receiptPrefixMerchandising || 'M' %>" />
      </label>
    </div>

    <label>
      Alerta baixo stock (valor default)
      <input type="number" name="default_low_stock_threshold" min="0" step="1" value="<%= typeof defaultLowStockThreshold === 'number' ? defaultLowStockThreshold : 5 %>" />
    </label>

    <button class="button primary" type="submit">Guardar</button>
  </form>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Logótipo da aplicação</h2>
  </div>

  <% if (brandMarkImage) { %>
    <div class="brand-preview">
      <img src="<%= brandMarkUrl %>" alt="Logotipo atual" />
    </div>
  <% } %>

  <form class="form-stack" method="post" action="/settings/branding" enctype="multipart/form-data">
    <label>
      Selecionar nova imagem
      <input type="file" name="image" accept="image/png, image/jpeg, image/webp" required />
    </label>

    <button class="button primary" type="submit">Atualizar logótipo</button>
  </form>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Interface</h2>
  </div>

  <label class="toggle-field">
    <input type="checkbox" data-vk-toggle />
    Teclado no ecrã (neste dispositivo)
  </label>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Segurança</h2>
  </div>

  <form class="form-stack" method="post" action="/settings/cancel-pin">
    <label>
      PIN admin para cancelamentos
      <input type="password" name="cancel_pin" inputmode="numeric" autocomplete="new-password" placeholder="Ex.: 1234" required />
    </label>
    <button class="button primary" type="submit">Guardar PIN</button>
  </form>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Email</h2>
  </div>

  <form class="form-stack" method="post" action="/settings/email">
    <div class="form-grid">
      <label>
        Servidor SMTP
        <input name="smtp_host" value="<%= emailSettings ? emailSettings.smtpHost : '' %>" placeholder="smtp.exemplo.pt" />
      </label>
      <label>
        Porta
        <input type="number" name="smtp_port" min="1" max="65535" value="<%= emailSettings ? emailSettings.smtpPort : 587 %>" />
      </label>
    </div>

    <label class="toggle-field">
      <input type="checkbox" name="smtp_secure" <%= emailSettings && emailSettings.smtpSecure ? "checked" : "" %> />
      Ligação segura direta (SSL/TLS)
    </label>

    <div class="form-grid">
      <label>
        Email de envio
        <input type="email" name="smtp_from" value="<%= emailSettings ? emailSettings.smtpFrom : '' %>" placeholder="clube@example.com" />
      </label>
      <label>
        Utilizador SMTP
        <input name="smtp_user" value="<%= emailSettings ? emailSettings.smtpUser : '' %>" autocomplete="username" />
      </label>
    </div>

    <label>
      Password SMTP
      <input type="password" name="smtp_pass" autocomplete="new-password" placeholder="<%= emailSettings && emailSettings.smtpPass ? 'Configurada - deixe vazio para manter' : '' %>" />
    </label>

    <label class="toggle-field">
      <input type="checkbox" name="send_member_welcome_email" <%= sendMemberWelcomeEmail ? "checked" : "" %> />
      Enviar email com estatutos quando um novo sócio for criado
    </label>

    <button class="button primary" type="submit">Guardar email</button>
  </form>

  <hr />

  <form class="form-stack" method="post" action="/settings/statutes-pdf" enctype="multipart/form-data">
    <% if (statutesPdfFile) { %>
      <p class="text-muted">PDF atual: <strong><%= statutesPdfFile %></strong></p>
    <% } %>
    <label>
      PDF dos estatutos
      <input type="file" name="statutes_pdf" accept="application/pdf,.pdf" required />
    </label>
    <button class="button secondary" type="submit">Atualizar PDF</button>
  </form>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Cotas</h2>
  </div>

  <form class="form-stack" method="post" action="/settings/dues">
    <label>
      Valor default da cota
      <input type="number" name="dues_default_amount" min="0" step="0.01" value="<%= duesDefaultAmount || 0 %>" />
    </label>
    <button class="button primary" type="submit">Guardar</button>
  </form>

  <hr />

  <form class="form-stack" method="post" action="/settings/dues/year">
    <label>
      Ano
      <input type="number" name="year" min="2000" max="2100" value="<%= new Date().getFullYear() %>" required />
    </label>
    <label>
      Valor da cota para o ano
      <input type="number" name="amount" min="0" step="0.01" value="<%= duesDefaultAmount || 0 %>" required />
    </label>
    <button class="button secondary" type="submit">Guardar valor por ano</button>
  </form>

  <% if (duesYears && duesYears.length > 0) { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Ano</th><th>Valor</th></tr></thead>
        <tbody>
          <% duesYears.forEach((row) => { %>
            <tr><td><%= row.year %></td><td><%= money(row.amount) %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Idioma</h2>
  </div>

  <form class="form-stack" method="post" action="/language">
    <input type="hidden" name="return_to" value="/settings" />
    <label>
      Idioma
      <select name="language">
        <% availableLanguages.forEach((item) => { %>
          <option value="<%= item.value %>" <%= item.code === locale ? "selected" : "" %>><%= item.label %></option>
        <% }) %>
      </select>
    </label>

    <button class="button secondary" type="submit">Aplicar idioma</button>
  </form>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Software</h2>
  </div>

  <div class="table-wrap">
    <table>
      <thead><tr><th>Dia</th><th>Versão do software</th></tr></thead>
      <tbody>
        <% if (softwareVersions && softwareVersions.length > 0) { %>
          <% softwareVersions.forEach((row) => { %>
            <tr>
              <td><%= new Intl.DateTimeFormat(locale, { dateStyle: "short" }).format(new Date(row.released_at)) %></td>
              <td><%= row.version %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="2">Sem versões registadas.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
