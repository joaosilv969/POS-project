<div class="login-brand">
  <span class="brand-mark">
    <% if (brandMarkImage) { %>
      <img src="/brand-mark" alt="Logótipo" />
    <% } else { %>
      B
    <% } %>
  </span>
  <h1>Bar POS</h1>
  <p>Entre para gerir vendas, stock e produtos.</p>
</div>

<form class="form-stack" method="post" action="/login">
  <label>
    PIN
    <input type="password" name="pin" inputmode="numeric" autocomplete="one-time-code" pattern="[0-9]{4,10}" required />
  </label>

  <p class="form-help">Introduza apenas o PIN do utilizador para entrar no sistema.</p>

  <label class="toggle-field compact">
    <input type="checkbox" data-vk-toggle />
    Teclado no ecrã
  </label>

  <button class="button primary full" type="submit">Entrar</button>
</form>

<div class="hint-box">
  <strong>ES O MAIOR !!!!!</strong>
</div>
