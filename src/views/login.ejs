<div class="login-brand">
  <span class="brand-mark">
    <% if (brandMarkImage) { %>
      <img src="<%= brandMarkUrl %>" alt="<%= t('Logótipo') %>" />
    <% } else { %>
      B
    <% } %>
  </span>
  <h1><%= appName %></h1>
  <p><%= t("Entre para gerir vendas, stock e produtos.") %></p>
</div>

<form class="form-stack" method="post" action="/login">
  <label>
    Email ou nome de utilizador
    <input type="text" name="identifier" autocomplete="username" />
  </label>

  <label>
    Password
    <input type="password" name="password" autocomplete="current-password" />
  </label>

  <p class="form-help">Entre com utilizador e palavra-passe ou, em alternativa, apenas com PIN.</p>

  <label>
    PIN
    <input type="password" name="pin" inputmode="numeric" autocomplete="one-time-code" pattern="[0-9]{4,10}" />
  </label>

  <label class="toggle-field compact">
    <input type="checkbox" data-vk-toggle />
    <%= t("Teclado no ecrã") %>
  </label>

  <button class="button primary full" type="submit"><%= t("Entrar") %></button>
</form>

<div class="hint-box">
  <strong>ES O MAIOR !!!!!</strong>
</div>
