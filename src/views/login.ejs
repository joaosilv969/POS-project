<div class="login-brand">
  <span class="brand-mark">
    <% if (brandMarkImage) { %>
      <img src="/brand-mark" alt="Logótipo" />
    <% } else { %>
      B
    <% } %>
  </span>
  <h1>Bar POS</h1>
  <p>Entre para gerir vendas, stock e produtos.</p>
</div>

<form class="form-stack" method="post" action="/login">
  <label>
    Email ou nome de utilizador
    <input type="text" name="identifier" autocomplete="username" required />
  </label>

  <label>
    Password
    <input type="password" name="password" autocomplete="current-password" required />
  </label>

  <label class="toggle-field compact">
    <input type="checkbox" data-vk-toggle />
    Teclado no ecrã
  </label>

  <button class="button primary full" type="submit">Entrar</button>
</form>

<div class="hint-box">
  <strong>Dados de teste</strong>
  <span>Administrador: admin@bar.local / admin123</span>
  <span>Funcionário: funcionario@bar.local / funcionario123</span>
</div>
